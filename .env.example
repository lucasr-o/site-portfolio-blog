# Copy to .env.local and fill in. Do NOT commit real secrets.

# Blog admin (Keystatic) — Basic Auth credentials shown in the browser popup.
ADMIN_USER=
ADMIN_PASSWORD=
# Random string; the /keystatic-4e411f3d entry sets this as a cookie to unlock
# the admin (anything works, e.g. `openssl rand -hex 24`).
ADMIN_GATE=

# GitHub storage — required to publish from the live deployed site.
# Obtain the GitHub App values via Keystatic's setup wizard (see README).
NEXT_PUBLIC_KEYSTATIC_REPO_OWNER=
NEXT_PUBLIC_KEYSTATIC_REPO_NAME=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
